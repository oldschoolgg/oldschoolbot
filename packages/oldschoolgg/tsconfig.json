{
	"extends": "../../tsconfig.base.json",
	"include": [".astro/types.d.ts", "src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["dist", "node_modules"],
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"composite": true,
		"rootDir": "src",
		"outDir": "dist",
		"paths": {
			"@/*": ["src/*"]
		},
		"baseUrl": ".",
		"lib": ["DOM"]
	}
}
