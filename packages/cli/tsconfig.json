{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "dist",
		"jsx": "react-jsx",
		"noEmit": false,
		"paths": {
			"@/*": ["../../src/*"],
			"@scripts/*": ["../../scripts/*"]
		},
		"isolatedModules": true
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"../../src/**/*.ts",
		"../../src/**/*.tsx",
		"../../scripts/**/*.ts",
		"../../scripts/**/*.tsx"
	],
	"exclude": ["dist", "node_modules"]
}
