{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"noEmit": true,
		"rootDir": "src",
		"outDir": "dist",
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},
		"isolatedDeclarations": true
	},
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": ["dist", "node_modules", "test", "scripts"]
}
